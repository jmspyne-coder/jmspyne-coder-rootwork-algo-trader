# Rootwork Algo Trader — environment template.
# Copy to .env and fill in. NEVER commit .env (see .gitignore).
# For GitHub Actions, set these as repo Secrets instead (Settings > Secrets > Actions).

# ─── Alpaca (required) ───────────────────────────────────
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# true = paper trading (paper-api), false = LIVE money. Keep true until vetted.
ALPACA_PAPER=true

# ─── MotherDuck (required for trade logging) ─────────────
MOTHERDUCK_TOKEN=

# ─── Notifications (optional — falls back to stdout) ─────
SLACK_WEBHOOK_URL=
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=            # Gmail App Password, NOT your account password
EMAIL_TO=                      # defaults to GMAIL_ADDRESS if blank

# ─── Strategy overrides (optional — see config/settings.py) ─
ALGO_TICKER=SPY
ALGO_ORB_MINUTES=5
ALGO_RR_RATIO=2.0
ALGO_STOP_MODE=atr            # "atr" or "midline"
ALGO_ATR_PERIOD=14
ALGO_ATR_STOP_MULT=1.5
ALGO_MIN_RANGE_PCT=0.003

# ─── Risk overrides (optional) ──────────────────────────
ALGO_RISK_PER_TRADE=0.03       # 3% of current equity (paper: of simulated equity)
ALGO_MAX_DAILY_LOSS=0.03       # hard daily stop: flatten + halt for the day (auto-resumes)
ALGO_DAILY_LOSS_WARN=0.0225    # early-warning email at 3/4 of the hard stop
ALGO_DAILY_FLOOR=0.50          # catastrophic floor: flatten + STICKY halt (manual resume)
ALGO_MAX_CONSEC_LOSSES=5       # consecutive losing days before a pause
ALGO_CONSEC_PAUSE_DAYS=2       # trading days to pause after a consec-loss halt (auto-resume)
ALGO_MAX_DRAWDOWN=0.10         # peak-to-current drawdown: STICKY halt (manual resume). $200 on $2k
ALGO_MAX_TRADES_DAY=2

# ─── Live account + paper tracker ───────────────────────────────────
ALGO_LIVE_CAPITAL=5000         # reference only; live sizing pulls actual equity and compounds
ALGO_PAPER_START=              # first paper day, ISO date (e.g. 2026-07-01) — enables the dashboard
ALGO_PAPER_DAYS=60             # minimum paper period before going live
ALGO_PAPER_BT_SHARPE=3.81      # backtest Sharpe reference shown in the dashboard (QQQ net@3bps)
# Paper sizes off a SIMULATED balance, not the pre-funded ~$100k paper account.
ALGO_PAPER_SIM_EQUITY=5000     # simulated starting equity for paper sizing
ALGO_PAPER_BASELINE=100000     # the paper account's starting balance (set to match if not ~$100k)

# ─── Backtest defaults (optional) ───────────────────────
ALGO_BT_START=2024-01-01
ALGO_BT_END=2026-06-01
ALGO_BT_CAPITAL=10000
